{
  "version": "2.0.0",
  "tasks": [
    // --- C语言编译任务 ---
    {
      "label": "build C",
      "type": "shell",
      "command": "gcc",
      "args": [
        "-g", "-O0",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.exe"
      ],
      "group": "build",
      "problemMatcher": "$gcc"
    },
    // --- C++编译任务 ---
    {
      "label": "build C++",
      "type": "shell",
      "command": "g++",
      "args": [
        "-g", "-O0",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.exe"
      ],
      "group": "build",
      "problemMatcher": "$gcc"
    }
  ]
}
