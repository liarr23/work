{
  "version": "0.2.0",
  "configurations": [
    // --- C语言调试配置 ---
    {
      "name": "调试 C 程序",
      "type": "cppdbg",
      "request": "launch",
      "program": "${fileDirname}/${fileBasenameNoExtension}.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${fileDirname}",
      "environment": [],
      "externalConsole": true,
      "MIMode": "gdb",
      "miDebuggerPath": "C:/Users/liar/Downloads/mingw/bin/gdb.exe",  // 改成你的GDB路径
      "setupCommands": [
        {
          "description": "启用美观打印",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "build C"  // 关联C编译任务
    },
    // --- C++调试配置 ---
    {
      "name": "调试 C++ 程序",
      "type": "cppdbg",
      "request": "launch",
      "program": "${fileDirname}/${fileBasenameNoExtension}.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${fileDirname}",
      "environment": [],
      "externalConsole": true,
      "MIMode": "gdb",
      "miDebuggerPath": "C:/Users/liar/Downloads/mingw/bin/gdb.exe",  // 同一个GDB即可
      "setupCommands": [
        {
          "description": "启用美观打印",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "build C++"  // 关联C++编译任务
    }
  ]
}
